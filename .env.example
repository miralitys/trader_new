APP_NAME=Trader Backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=replace-me
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

POSTGRES_DB=trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/trader
REDIS_URL=redis://redis:6379/0

BINANCE_US_API_BASE_URL=https://api.binance.us
BINANCE_US_TIMEOUT_SECONDS=20
BINANCE_US_MAX_CANDLES_PER_REQUEST=1000
BINANCE_US_RETRY_ATTEMPTS=5
BINANCE_US_BACKOFF_MIN_SECONDS=1.0
BINANCE_US_BACKOFF_MAX_SECONDS=8.0
BINANCE_SPOT_API_BASE_URL=https://api.binance.com
BINANCE_FUTURES_API_BASE_URL=https://fapi.binance.com
BINANCE_SPOT_MAX_ROWS_PER_REQUEST=1000
BINANCE_FUTURES_MAX_ROWS_PER_REQUEST=1000
BINANCE_FUTURES_OPEN_INTEREST_MAX_ROWS_PER_REQUEST=500
BINANCE_FUTURES_MAX_FUNDING_ROWS_PER_REQUEST=1000
FUNDING_BASIS_TIMEOUT_SECONDS=20
FUNDING_BASIS_RETRY_ATTEMPTS=5
FUNDING_BASIS_BACKOFF_MIN_SECONDS=1.0
FUNDING_BASIS_BACKOFF_MAX_SECONDS=8.0
OKX_API_BASE_URL=https://www.okx.com
OKX_MAX_ROWS_PER_REQUEST=100
OKX_MAX_FUNDING_ROWS_PER_REQUEST=100
FUNDING_BASIS_ARCHIVE_BASE_URL=https://data.binance.vision/data
FUNDING_BASIS_ARCHIVE_FALLBACK_ENABLED=true
FUNDING_BASIS_ARCHIVE_PREFER_ARCHIVE=false
FUNDING_BASIS_INCREMENTAL_OVERLAP_BARS=3
FUNDING_BASIS_INCREMENTAL_FUNDING_OVERLAP_INTERVALS=1
FUNDING_BASIS_DEFAULT_BACKFILL_DAYS=30
MARKET_DATA_INCREMENTAL_OVERLAP_CANDLES=3

DEFAULT_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,ADA-USDT,ALPINE-USDT,XRP-USDT,1INCH-USDT
DEFAULT_TIMEFRAMES=5m,15m,1h
WORKER_POLL_SECONDS=15
WORKER_MAX_CANDLES_PER_STREAM=100
BACKTEST_STALE_AFTER_SECONDS=14400

BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
