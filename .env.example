APP_NAME=Trader Backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=replace-me
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

POSTGRES_DB=trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/trader
REDIS_URL=redis://redis:6379/0

COINBASE_API_BASE_URL=https://api.exchange.coinbase.com
COINBASE_TIMEOUT_SECONDS=20
COINBASE_MAX_CANDLES_PER_REQUEST=300
COINBASE_RETRY_ATTEMPTS=5
COINBASE_BACKOFF_MIN_SECONDS=1.0
COINBASE_BACKOFF_MAX_SECONDS=8.0
MARKET_DATA_INCREMENTAL_OVERLAP_CANDLES=3

DEFAULT_SYMBOLS=BTC-USD,ETH-USD,SOL-USD
DEFAULT_TIMEFRAMES=5m,15m,1h
WORKER_POLL_SECONDS=15
WORKER_MAX_CANDLES_PER_STREAM=100

BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
